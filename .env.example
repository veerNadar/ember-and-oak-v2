# ── Supabase ───────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── NextAuth ────────────────────────────────────────────────────────────────
# NEXTAUTH_SECRET: generate with `openssl rand -hex 32`
# NEXTAUTH_URL: set to your production URL on deployment (e.g. https://www.emberandoak.com)
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# ── Admin credentials ───────────────────────────────────────────────────────
# Plain-text username (used as the display name in the admin panel)
ADMIN_USERNAME=
# Plain-text password checked with bcrypt at login
# Generate hash: node -e "const b=require('bcryptjs');b.hash('yourpassword',12).then(console.log)"
ADMIN_PASSWORD=
